# HFBS v2 — Environment Variables
# Скопируй в .env и заполни перед деплоем

# Django
DJANGO_SECRET_KEY=change-me-in-production-use-random-string
DEBUG=False

# PostgreSQL
POSTGRES_DB=hfbs
POSTGRES_USER=hfbs
POSTGRES_PASSWORD=hfbs_pass_change_me

# Redis
REDIS_URL=redis://redis:6380

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# FastAPI JWT
SECRET_KEY=change-me-jwt-secret-random-string

# Antifrod
MODEL_PATH=/app/models/antifrod_model.pkl

# URLs (внутренние — не менять)
DATABASE_URL=postgresql+asyncpg://hfbs:hfbs_pass_change_me@postgres:5432/hfbs
ANTIFROD_URL=http://antifrod:9303
